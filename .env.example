# /opt/fc-landing-api/shared/.env — production secrets
# НЕ коммитить. Реальный файл лежит только на VPS.

# Токен бота из @BotFather
TG_BOT_TOKEN=0000000000:AAExampleTokenReplaceMe

# Chat ID приватной TG-группы (с минусом, например: -5284448064)
TG_CHAT_ID=-0000000000

# CORS allowlist (через запятую, без слэша на конце)
ALLOWED_ORIGINS=https://media-konveyer.ru,https://www.media-konveyer.ru

# Локальный порт (nginx проксирует на него)
PORT=3022
