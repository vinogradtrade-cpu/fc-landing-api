# /opt/fc-landing-api/shared/.env — production secrets
# НЕ коммитить. Реальный файл лежит только на VPS.

# Токен бота из @BotFather
TG_BOT_TOKEN=0000000000:AAExampleTokenReplaceMe

# Chat ID приватной TG-группы (с минусом, например: -5284448064)
TG_CHAT_ID=-0000000000

# Секрет для Telegram webhook (заголовок X-Telegram-Bot-Api-Secret-Token)
TG_WEBHOOK_SECRET=replace_me_64_hex_chars

# Админский токен — для /api/admin/* эндпоинтов (Authorization: Bearer ...)
# Сгенерировать: openssl rand -hex 32
ADMIN_TOKEN=replace_me_64_hex_chars

# Базовый URL сайта — используется при формировании ссылок на бриф
PUBLIC_BASE_URL=https://media-konveyer.ru

# CORS allowlist (через запятую, без слэша на конце)
ALLOWED_ORIGINS=https://media-konveyer.ru,https://www.media-konveyer.ru

# Локальный порт (nginx проксирует на него)
PORT=3022

# SQLite-файл с брифами (по умолчанию /opt/fc-landing-api/shared/briefs.db)
BRIEF_DB_PATH=/opt/fc-landing-api/shared/briefs.db
BRIEF_TOKEN_LIFETIME_DAYS=14
